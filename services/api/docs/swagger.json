{
    "swagger": "2.0",
    "info": {
        "description": "REST-фасад Vigil: метрики из storage и текущие алерты. Защищено JWT.",
        "title": "Vigil API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/alerts": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "alerts"
                ],
                "summary": "Текущие горящие алерты",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/main.AlertDTO"
                            }
                        }
                    },
                    "401": {
                        "description": "нет/невалидный токен",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "ошибка redis",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/login": {
            "post": {
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "auth"
                ],
                "summary": "Логин, выдаёт JWT-токен",
                "parameters": [
                    {
                        "description": "логин и пароль",
                        "name": "credentials",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "type": "object"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "поле signed — JWT-токен",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "400": {
                        "description": "неверное тело запроса",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "401": {
                        "description": "неверные учётные данные",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/metrics": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "metrics"
                ],
                "summary": "Список метрик за период",
                "parameters": [
                    {
                        "type": "string",
                        "description": "хост",
                        "name": "host",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "имя метрики (напр. cpu_usage_percent)",
                        "name": "name",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "начало периода, RFC3339",
                        "name": "from",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "конец периода, RFC3339",
                        "name": "to",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "макс. число точек",
                        "name": "limit",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/main.MetricDTO"
                            }
                        }
                    },
                    "400": {
                        "description": "неверные параметры",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "401": {
                        "description": "нет/невалидный токен",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "ошибка storage",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "main.AlertDTO": {
            "type": "object",
            "properties": {
                "host": {
                    "type": "string"
                },
                "rule": {
                    "type": "string"
                }
            }
        },
        "main.MetricDTO": {
            "type": "object",
            "properties": {
                "host": {
                    "type": "string"
                },
                "labels": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "string"
                    }
                },
                "name": {
                    "type": "string"
                },
                "ts": {
                    "type": "string"
                },
                "value": {
                    "type": "number"
                }
            }
        }
    },
    "securityDefinitions": {
        "BearerAuth": {
            "type": "apiKey",
            "name": "Authorization",
            "in": "header"
        }
    }
}